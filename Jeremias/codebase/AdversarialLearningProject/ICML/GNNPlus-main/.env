# ADVERSARIAL LEARNING (PERSON-INVARIANCE)
# This module implements a Gradient Reversal Layer (GRL) and a Participant Discriminator head.
# During training, the Discriminator tries to identify the participant from the graph features, 
# while the GRL flips the gradients to force the GNN encoder to "erase" any person-specific signatures.
# Effectively, the model is punished for recognizing WHO is doing the gesture, forcing it to focus 
# ONLY on the spatial-temporal mechanics of the exercise itself.
#
# *ADVANCED STABILIZATION*: 
# 1. Spectral Normalization (SN) surrounds the discriminator's linear layers to cap its Lipschitz
#    constant at 1. This prevents the discriminator from optimizing too quickly and destroying the
#    encoder's gesture representations with chaotic back-flowing gradients.
# 2. A separate "Private Gesture Branch" is used for the main predictive head to decouple identity
#    erasure from the gesture mechanics, preventing feature starvation.
USE_ADVERSARIAL_LAYERS=false

# SUPERVISED CONTRASTIVE LEARNING (CLUSTER-BASED INVARIANCE)
# This module adds a Projection Head that maps graph features into a normalized latent space.
# It uses the SupCon loss to force features of the SAME exercise (from different people) 
# to cluster together, while pushing features of DIFFERENT exercises far apart. 
# This actively shapes the feature space to be exercise-centric and person-neutral, 
# providing a more geometric approach to invariance than the adversarial head.
#
# *OPTIMIZATION SYNERGY*:
# The module utilizes a Dynamic Linear Warmup Schedule (`lambda_con` scales 0.0 -> 0.5).
# By delaying the contrastive clustering force until later in the epochs, the main GNN 
# convolution backbone is given breathing room to learn the basic spatial graph topology 
# before it's forced to re-arrange its global latent space distances.
USE_CONTRASTIVE_LEARNING=true

# PERSON-EXCLUSIVE LEARNING (ZERO-SHOT VALIDATION)
# This module forces the model to be tested on people it has NEVER seen during training.
# True person-invariance means a model should work on a complete stranger.
# If true, it uses the participant IDs below for val/test.
USE_PERSON_EXCLUSIVE_SPLIT=true
EXCLUDE_PERSON_ID_VAL=2
EXCLUDE_PERSON_ID_TEST=3

# THE TRUE STRESS TEST: Train on 2 subjects, Test on 14
# When true, this overrides the default PX settings to create a low-data generalization challenge.
USE_STRESS_TEST=false